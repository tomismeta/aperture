        "summary": "The cache rebuild is still blocked.",
        "status": "failed",
        "semanticHints": {
          "relationHints": [
            { "kind": "same_issue", "target": "issue:cache:prod" },
            { "kind": "repeats", "target": "issue:cache:prod" }
          ]
        }
      }
    },
    {
      "kind": "publishSource",
      "label": "wording drift follow-up",
      "event": {
        "id": "evt:cache-followup",
        "type": "task.updated",
        "taskId": "task:cache-followup",
        "timestamp": "2026-03-20T13:12:15.000Z",
        "source": { "id": "custom-agent" },
        "title": "Resync remains stalled again",
        "summary": "The same cache issue is still running through recovery.",
        "status": "running",
        "semanticHints": {
          "relationHints": [
            { "kind": "same_issue", "target": "issue:cache:prod" },
            { "kind": "repeats", "target": "issue:cache:prod" }
