{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "baseUrl": ".",
    "paths": {
      "@aperture/core": ["packages/core/src/index.ts"],
      "@aperture/cli": ["packages/cli/src/index.ts"],
      "@aperture/codex": ["packages/codex/src/index.ts"],
      "@aperture/paperclip": ["packages/paperclip/src/index.ts"]
    }
  }
}
