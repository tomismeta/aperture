{
  "name": "aperture",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.29.1",
  "scripts": {
    "build": "tsc -b",
    "claude:serve": "tsx scripts/claude-hook-server.ts",
    "claude:tui": "pnpm tui",
    "clean": "rm -rf packages/*/dist",
    "demo:claude-hook": "tsx scripts/demo-claude-stack.ts",
    "demo:tui": "tsx scripts/demo-tui.ts",
    "serve": "tsx scripts/runtime-server.ts",
    "setup:claude-hook": "node scripts/setup-claude-hook.mjs",
    "test": "tsx --test packages/*/test/**/*.test.ts",
    "tui": "tsx scripts/claude-hook-tui.ts",
    "typecheck": "tsc -b --pretty"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.5",
    "typescript": "^5.8.3"
  }
}
