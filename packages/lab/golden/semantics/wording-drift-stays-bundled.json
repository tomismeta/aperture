{
  "id": "golden:semantics:wording-drift-stays-bundled",
  "title": "Wording drift stays bundled when relation targets match",
  "description": "Different phrasing about the same issue should stay in the same episode so follow-up status does not steal focus from the active blocker.",
  "doctrineTags": [
    "semantic_normalization",
    "semantic_robustness",
    "relation_semantics",
    "decision_stream_continuity",
    "ambient_doctrine"
  ],
  "expectations": {
    "finalActiveInteractionId": "interaction:task:cache-blocker:status",
    "queuedInteractionIds": [],
    "ambientInteractionIds": [
      "interaction:task:cache-followup:status"
    ],
    "resultBucketCounts": {
      "active": 1,
      "queued": 0,
      "ambient": 1
    },
    "semanticReadings": [
      {
        "stepLabel": "wording drift follow-up",
        "intentFrame": "status_update",
        "activityClass": "status_update",
        "consequence": "low",
        "relationKindsInclude": ["same_issue", "repeats"]
      }
    ]
  },
  "steps": [
